{
  "name": "@mergewire/action",
  "version": "1.2.2",
  "description": "GitHub Action to run Terraform and send routing-safe payloads to the review router API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "package": "ncc build dist/index.js -o dist-packed --license licenses.txt",
    "release": "npm run build && npm run package",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml}\" --ignore-path .prettierignore"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
